# =============================================================================
# Real Care — Environment Variables
# =============================================================================
# Copy this file to .env (or configure each value in Lovable → Settings →
# Environment Variables) and fill in real values before going live.
#
# Variables prefixed with VITE_ are exposed to the browser bundle. Never put
# secret keys in VITE_ vars. Server-only secrets (Stripe secret key, OpenLoop
# API key, webhook signing secrets, service role key) belong in Supabase
# Edge Function secrets, NOT in this file.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (auto-provisioned by Lovable Cloud — usually no action needed)
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGci...
VITE_SUPABASE_PROJECT_ID=your-project-ref

# -----------------------------------------------------------------------------
# Stripe — Publishable key (browser-safe)
# Get from: Stripe Dashboard → Developers → API keys
# -----------------------------------------------------------------------------
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# -----------------------------------------------------------------------------
# Stripe — Price lookup keys (must match keys created in Stripe Dashboard)
# These are referenced in src/pages/Pricing.tsx and product pages.
# Get from: Stripe Dashboard → Products → [Product] → Pricing → lookup_key
# -----------------------------------------------------------------------------

# Weight Loss — GLP-1 (Medvi-style two-step pricing)
VITE_STRIPE_PRICE_WL_FIRST=weight_loss_glp1_first_month        # $179 first month
VITE_STRIPE_PRICE_WL_RECURRING=weight_loss_glp1_monthly        # $299/mo ongoing
VITE_STRIPE_PRICE_WL_QUARTERLY=weight_loss_glp1_quarterly      # 3-month prepay
VITE_STRIPE_PRICE_WL_SEMIANNUAL=weight_loss_glp1_semiannual    # 6-month prepay
VITE_STRIPE_PRICE_WL_ANNUAL=weight_loss_glp1_annual            # 12-month prepay (~$2,148)

# Weight Loss — Tirzepatide
VITE_STRIPE_PRICE_TIRZ_FIRST=weight_loss_tirz_first_month
VITE_STRIPE_PRICE_TIRZ_RECURRING=weight_loss_tirz_monthly

# Weight Loss — Oral semaglutide
VITE_STRIPE_PRICE_WL_ORAL=weight_loss_oral_monthly

# Men
VITE_STRIPE_PRICE_TRT=trt_monthly
VITE_STRIPE_PRICE_ED=ed_treatment_monthly
VITE_STRIPE_PRICE_HAIR_MEN=hair_mens_monthly
VITE_STRIPE_PRICE_PEPTIDES=peptides_monthly

# Women
VITE_STRIPE_PRICE_HRT=menopause_hrt_monthly
VITE_STRIPE_PRICE_SKINCARE=skincare_monthly
VITE_STRIPE_PRICE_HAIR_WOMEN=hair_womens_monthly
VITE_STRIPE_PRICE_SEXUAL_HEALTH_W=sexual_health_womens_monthly
VITE_STRIPE_PRICE_BIRTH_CONTROL=birth_control_monthly

# Shared
VITE_STRIPE_PRICE_MENTAL_HEALTH=mental_health_monthly
VITE_STRIPE_PRICE_SLEEP=sleep_monthly
VITE_STRIPE_PRICE_SUPPLEMENTS=supplements_monthly
VITE_STRIPE_PRICE_LAB_TESTING=lab_testing_one_time

# -----------------------------------------------------------------------------
# Analytics & Marketing Pixels (browser-safe)
# -----------------------------------------------------------------------------
VITE_GA4_ID=G-XXXXXXXXXX                     # Google Analytics → Admin → Data Streams
VITE_META_PIXEL_ID=000000000000000           # Meta Business → Events Manager
VITE_TIKTOK_PIXEL_ID=                        # Optional — TikTok Ads Manager
VITE_KLAVIYO_PUBLIC_KEY=ABCDEF               # Klaviyo → Account → API Keys (public key)

# Klaviyo list IDs (for client-side list subscriptions)
VITE_KLAVIYO_LIST_ALL=
VITE_KLAVIYO_LIST_WEIGHT_LOSS=
VITE_KLAVIYO_LIST_MENS=
VITE_KLAVIYO_LIST_WOMENS=

# -----------------------------------------------------------------------------
# Site config
# -----------------------------------------------------------------------------
VITE_SITE_URL=https://realcare.com
VITE_SUPPORT_EMAIL=support@realcare.com
VITE_SUPPORT_PHONE=

# =============================================================================
# SERVER-ONLY SECRETS — DO NOT COMMIT VALUES
# Configure these in Lovable Cloud → Backend → Secrets (NOT in this file).
# Listed here for reference only.
# =============================================================================
#
# STRIPE_SANDBOX_API_KEY            # Auto-managed by Lovable Cloud
# STRIPE_LIVE_API_KEY               # Auto-managed once you go live
# PAYMENTS_SANDBOX_WEBHOOK_SECRET   # Auto-managed
# PAYMENTS_LIVE_WEBHOOK_SECRET      # Auto-managed once you go live
# LOVABLE_API_KEY                   # Auto-managed
#
# OPENLOOP_API_KEY                  # OpenLoop partner dashboard
# OPENLOOP_WEBHOOK_SECRET           # OpenLoop partner dashboard
#
# KLAVIYO_PRIVATE_API_KEY           # Klaviyo → Account → API Keys (private key)
#
# RESEND_API_KEY                    # Optional — transactional email
#
# SUPABASE_URL                      # Auto-injected in edge functions
# SUPABASE_SERVICE_ROLE_KEY         # Auto-injected in edge functions
# SUPABASE_ANON_KEY                 # Auto-injected in edge functions
